PORT=3000

# Project ref: xhuejsxfohmjizvrkpgn (m-service / mservice)
SUPABASE_URL=https://xhuejsxfohmjizvrkpgn.supabase.co

# Get SERVICE_ROLE key from: Supabase dashboard → Project Settings → API → service_role secret.
# Never commit the real key. Keep it server-side only.
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret for signing auth tokens. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set this in the Render dashboard env vars. Never commit the real value.
JWT_SECRET=

# S3 Storage Configuration
S3_ENDPOINT=https://s3.spb.sprinthost.ru
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=spb
S3_BUCKET=s3-942930

# Deployment:
# Production runs on Render.com at https://avtogrom-serverl.onrender.com
# The server/ folder is its own git repo. Pushes to it auto-deploy on Render.
# SUPABASE_SERVICE_ROLE_KEY and JWT_SECRET are set as env vars in the Render dashboard, not committed.
